@page "/reset-password"
@attribute [Authorize(Policy = "KeyUserOnly")]
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using AdminAssistant.Core.Interfaces
@using AdminAssistant.Core.Models

@inject IAdService AdService
@inject AuthenticationStateProvider AuthProvider

<PageTitle>Kennwort zurücksetzen</PageTitle>

<h3>Kennwort zurücksetzen</h3>

@if (resultMessage != null)
{
    <div class="alert @alertClass">@resultMessage</div>
}

<EditForm Model="@model" OnValidSubmit="HandleReset">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>Benutzer suchen</label>
        <input class="form-control"
               value="@searchTerm"
               @oninput="OnSearchInput"
               placeholder="Name oder SAM-Account eingeben..." />

        @if (suggestions.Any())
        {
            <ul class="list-group mt-1" style="position:absolute; z-index:1000; width:400px;">
                @foreach (var user in suggestions)
                {
                    <li class="list-group-item list-group-item-action"
                        style="cursor:pointer"
                        @onclick="() => SelectUser(user)">
                        <strong>@user.DisplayName</strong>
                        <small class="text-muted ms-2">@user.SamAccountName</small>
                        @if (!string.IsNullOrEmpty(user.Email))
                        {
                            <small class="text-muted ms-2">– @user.Email</small>
                        }
                    </li>
                }
            </ul>
        }
    </div>

    <div class="mb-3">
        <label>Ausgewählter Benutzer</label>
        <input class="form-control" value="@model.TargetUsername" readonly />
    </div>

    <div class="mb-3">
        <label>Neues Kennwort</label>
        <InputText class="form-control" type="password" @bind-Value="model.NewPassword" />
    </div>

    <button class="btn btn-primary" type="submit"
            disabled="@(isLoading || string.IsNullOrEmpty(model.TargetUsername))">
        @(isLoading ? "Wird ausgeführt..." : "Kennwort zurücksetzen")
    </button>
</EditForm>

@code {
    private ResetModel model = new();
    private string searchTerm = string.Empty;
    private List<AdUserResult> suggestions = new();
    private string? resultMessage;
    private string alertClass = "alert-success";
    private bool isLoading = false;

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;
        model.TargetUsername = string.Empty; // Auswahl zurücksetzen

        if (searchTerm.Length >= 2)
            suggestions = (await AdService.SearchUsersAsync(searchTerm)).ToList();
        else
            suggestions.Clear();
    }

    private void SelectUser(AdUserResult user)
    {
        model.TargetUsername = user.SamAccountName;
        searchTerm = $"{user.DisplayName} ({user.SamAccountName})";
        suggestions.Clear();
    }

    private async Task HandleReset()
    {
        isLoading = true;
        resultMessage = null;

        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var keyUser = authState.User.Identity?.Name ?? "Unbekannt";

        var success = await AdService.ResetPasswordAsync(
            model.TargetUsername, model.NewPassword, keyUser);

        alertClass = success ? "alert-success" : "alert-danger";
        resultMessage = success
            ? $"✅ Kennwort für '{model.TargetUsername}' erfolgreich zurückgesetzt."
            : $"❌ Fehler beim Zurücksetzen für '{model.TargetUsername}'.";

        if (success) model = new ResetModel();
        isLoading = false;
    }

    private class ResetModel
    {
        public string TargetUsername { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MinLength(8, ErrorMessage = "Mindestens 8 Zeichen.")]
        public string NewPassword { get; set; } = string.Empty;
    }
}
