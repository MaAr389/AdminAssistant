@page "/vpn-management"
@attribute [Authorize(Policy = "KeyUserOnly")]
@rendermode InteractiveServer

@using System.Text
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using AdminAssistant.Core.Interfaces
@using AdminAssistant.Core.Models

@inject IAdService AdService
@inject IOuAccessService OuAccessService
@inject IVpnInventoryService VpnInventoryService
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS

<PageTitle>VPN</PageTitle>

<div class="d-flex align-items-center mb-4">
    <span class="bi bi-shield-lock-fill me-2 fs-4 text-primary"></span>
    <h3 class="mb-0">VPN</h3>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card border-0 bg-primary-subtle h-100">
            <div class="card-body py-3">
                <div class="text-muted small">Lizenzen gesamt</div>
                <div class="fs-4 fw-semibold">@inventory.TotalLicenses</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card border-0 bg-success-subtle h-100">
            <div class="card-body py-3">
                <div class="text-muted small">Lizenzen frei</div>
                <div class="fs-4 fw-semibold">@inventory.AvailableLicenses</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card border-0 bg-secondary-subtle h-100">
            <div class="card-body py-3">
                <div class="text-muted small">Reader gesamt</div>
                <div class="fs-4 fw-semibold">@inventory.TotalReaders</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card border-0 bg-warning-subtle h-100">
            <div class="card-body py-3">
                <div class="text-muted small">Reader vergeben</div>
                <div class="fs-4 fw-semibold">@inventory.AssignedReaders</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card border-0 bg-secondary-subtle h-100">
            <div class="card-body py-3">
                <div class="text-muted small">Karten gesamt</div>
                <div class="fs-4 fw-semibold">@inventory.TotalCards</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
        <div class="card border-0 bg-warning-subtle h-100">
            <div class="card-body py-3">
                <div class="text-muted small">Karten vergeben</div>
                <div class="fs-4 fw-semibold">@inventory.AssignedCards</div>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(inventoryMessage))
{
    <div class="alert alert-info py-2">@inventoryMessage</div>
}

<div class="row g-4 mb-4">
    <div class="col-12 col-xl-6">
        <div class="card shadow-sm h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-usb-symbol me-2"></i>Smartcardreader</span>
                <span class="badge bg-primary">@readerRows.Count</span>
            </div>
            <div class="card-body border-bottom">
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-4">
                        <label class="form-label small">Seriennummer</label>
                        <input class="form-control form-control-sm" @bind="newReaderSerial" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label small">AD Benutzer</label>
                        <input class="form-control form-control-sm" @bind="newReaderAssignedUser" placeholder="DOM\\user oder UPN" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label small">Beschreibung</label>
                        <input class="form-control form-control-sm" @bind="newReaderDescription" />
                    </div>
                    <div class="col-12">
                        <button class="btn btn-sm btn-primary" @onclick="AddReaderAsync" disabled="@inventoryBusy">
                            <i class="bi bi-plus-circle me-1"></i>Reader hinzufügen
                        </button>
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Seriennummer</th>
                            <th>AD Benutzer</th>
                            <th>Beschreibung</th>
                            <th>Zugewiesen</th>
                            <th style="width:130px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (readerRows.Count == 0)
                        {
                            <tr><td colspan="5" class="text-muted text-center py-3">Keine Reader vorhanden.</td></tr>
                        }
                        else
                        {
                            @foreach (var row in readerRows)
                            {
                                <tr>
                                    <td><input class="form-control form-control-sm" @bind="row.SerialNumber" /></td>
                                    <td><input class="form-control form-control-sm" @bind="row.AssignedAdUser" /></td>
                                    <td><input class="form-control form-control-sm" @bind="row.Description" /></td>
                                    <td>@FormatDate(row.AssignedAt)</td>
                                    <td class="text-nowrap">
                                        <button class="btn btn-sm btn-outline-success me-1" @onclick="() => SaveReaderAsync(row)" disabled="@inventoryBusy"><i class="bi bi-save"></i></button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteReaderAsync(row.Id)" disabled="@inventoryBusy"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-12 col-xl-6">
        <div class="card shadow-sm h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-credit-card me-2"></i>Karten</span>
                <span class="badge bg-primary">@cardRows.Count</span>
            </div>
            <div class="card-body border-bottom">
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-3">
                        <label class="form-label small">Kartennummer</label>
                        <input class="form-control form-control-sm" @bind="newCardNumber" />
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label small">AD Benutzer</label>
                        <input class="form-control form-control-sm" @bind="newCardAssignedUser" />
                    </div>
                    <div class="col-12 col-md-2">
                        <label class="form-label small">PIN</label>
                        <input class="form-control form-control-sm" @bind="newCardPin" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label small">Notiz</label>
                        <input class="form-control form-control-sm" @bind="newCardNotes" />
                    </div>
                    <div class="col-12">
                        <button class="btn btn-sm btn-primary" @onclick="AddCardAsync" disabled="@inventoryBusy">
                            <i class="bi bi-plus-circle me-1"></i>Karte hinzufügen
                        </button>
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Karte</th>
                            <th>AD Benutzer</th>
                            <th>PIN</th>
                            <th>Notiz</th>
                            <th>Ausgegeben</th>
                            <th style="width:130px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (cardRows.Count == 0)
                        {
                            <tr><td colspan="6" class="text-muted text-center py-3">Keine Karten vorhanden.</td></tr>
                        }
                        else
                        {
                            @foreach (var row in cardRows)
                            {
                                <tr>
                                    <td><input class="form-control form-control-sm" @bind="row.CardNumber" /></td>
                                    <td><input class="form-control form-control-sm" @bind="row.AssignedAdUser" /></td>
                                    <td><input class="form-control form-control-sm" @bind="row.Pin" /></td>
                                    <td><input class="form-control form-control-sm" @bind="row.Notes" /></td>
                                    <td>@FormatDate(row.IssuedAt)</td>
                                    <td class="text-nowrap">
                                        <button class="btn btn-sm btn-outline-success me-1" @onclick="() => SaveCardAsync(row)" disabled="@inventoryBusy"><i class="bi bi-save"></i></button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteCardAsync(row.Id)" disabled="@inventoryBusy"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
            <button class="btn btn-outline-primary btn-sm" @onclick="LoadAllUsersAsync" disabled="@isLoading">
                <i class="bi bi-people-fill me-1"></i>Alle Benutzer laden
            </button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleAllSelections" disabled="@(!CanSelectAll)">
                <i class="bi bi-check2-square me-1"></i>@(AllSelected ? "Alle abwählen" : "Alle markieren")
            </button>
            <button class="btn btn-success btn-sm" @onclick="GenerateHex64Strings" disabled="@(selectedUsers.Count == 0)">
                <i class="bi bi-code-slash me-1"></i>HEX64 erzeugen
            </button>
            <button class="btn btn-outline-success btn-sm" @onclick="ExportCsvAsync" disabled="@(encodedResults.Count == 0)">
                <i class="bi bi-filetype-csv me-1"></i>CSV Export
            </button>
        </div>

        <div class="input-group">
            <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
            <input class="form-control border-start-0"
                   value="@searchTerm"
                   @oninput="OnSearchChangedAsync"
                   placeholder="User suchen (Name, SAM oder UPN; mind. 2 Zeichen)" />
            @if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                <button class="btn btn-outline-secondary" @onclick="ClearSearch">✕</button>
            }
        </div>
        <div class="form-text">Bei Suche werden nur passende Benutzer geladen; ohne Suche kannst du alle Benutzer laden.</div>
    </div>
</div>

@if (isLoading)
{
    <div class="text-center py-4 text-muted">
        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
        Lade Benutzer...
    </div>
}
else if (results is null)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-search fs-1 d-block mb-3"></i>
        Entweder alle Benutzer laden oder nach einem einzelnen Benutzer suchen.
    </div>
}
else
{
    <div class="row g-4 align-items-start">
        <div class="col-12 col-xl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-list-ul me-2"></i>@resultTitle</span>
                    <span class="badge bg-primary">@results.Count Benutzer</span>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width:48px;"></th>
                                <th>Anzeigename</th>
                                <th>UPN</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in results)
                            {
                                var upn = GetUpn(user);
                                <tr>
                                    <td>
                                        <input type="checkbox"
                                               class="form-check-input"
                                               checked="@selectedUsers.Contains(user.SamAccountName)"
                                               @onchange="e => ToggleSelection(user.SamAccountName, ParseCheckboxValue(e.Value))" />
                                    </td>
                                    <td>@user.DisplayName</td>
                                    <td><code>@upn</code></td>
                                    <td>
                                        @if (user.IsEnabled)
                                        {
                                            <span class="badge bg-success">Enable</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Disable</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-file-code me-2"></i>HEX64 Ergebnis</span>
                    <span class="badge bg-success">@encodedResults.Count Einträge</span>
                </div>

                @if (encodedResults.Count == 0)
                {
                    <div class="card-body text-muted">Noch keine HEX64-Werte erzeugt.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-striped mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Anzeigename</th>
                                    <th>HEX64</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in encodedResults)
                                {
                                    <tr>
                                        <td>@item.DisplayName</td>
                                        <td><code>@item.Encoded</code></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading;
    private bool isAdmin;
    private bool inventoryBusy;
    private string searchTerm = string.Empty;
    private string resultTitle = "Benutzerliste";
    private string inventoryMessage = string.Empty;
    private List<AdUserResult>? results;
    private VpnInventoryOverview inventory = new();
    private List<VpnSmartcardReader> readerRows = new();
    private List<VpnAccessCard> cardRows = new();

    private string newReaderSerial = string.Empty;
    private string newReaderAssignedUser = string.Empty;
    private string newReaderDescription = string.Empty;

    private string newCardNumber = string.Empty;
    private string newCardAssignedUser = string.Empty;
    private string newCardPin = string.Empty;
    private string newCardNotes = string.Empty;

    private readonly HashSet<string> selectedUsers = new(StringComparer.OrdinalIgnoreCase);
    private readonly List<EncodedVpnUser> encodedResults = new();

    private bool CanSelectAll => results is { Count: > 0 };

    private bool AllSelected => CanSelectAll && results!.All(x => selectedUsers.Contains(x.SamAccountName));

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        isAdmin = authState.User.IsInRole(@"SP\GRP_Admin_AdminAssistant");
        await LoadInventoryAsync();
    }

    private async Task LoadInventoryAsync()
    {
        inventory = await VpnInventoryService.GetOverviewAsync();
        readerRows = await VpnInventoryService.GetReadersAsync();
        cardRows = await VpnInventoryService.GetCardsAsync();
    }

    private async Task AddReaderAsync()
    {
        if (string.IsNullOrWhiteSpace(newReaderSerial))
            return;

        var entity = new VpnSmartcardReader
        {
            SerialNumber = newReaderSerial,
            AssignedAdUser = newReaderAssignedUser,
            Description = newReaderDescription,
            AssignedAt = string.IsNullOrWhiteSpace(newReaderAssignedUser) ? null : DateTime.Now
        };

        await RunInventoryActionAsync(async () =>
        {
            await VpnInventoryService.AddReaderAsync(entity);
            newReaderSerial = string.Empty;
            newReaderAssignedUser = string.Empty;
            newReaderDescription = string.Empty;
        }, "Reader angelegt.");
    }

    private async Task SaveReaderAsync(VpnSmartcardReader row)
    {
        row.AssignedAt = string.IsNullOrWhiteSpace(row.AssignedAdUser) ? null : row.AssignedAt ?? DateTime.Now;
        await RunInventoryActionAsync(async () => await VpnInventoryService.UpdateReaderAsync(row), "Reader gespeichert.");
    }

    private async Task DeleteReaderAsync(int id)
    {
        await RunInventoryActionAsync(() => VpnInventoryService.DeleteReaderAsync(id), "Reader gelöscht.");
    }

    private async Task AddCardAsync()
    {
        if (string.IsNullOrWhiteSpace(newCardNumber))
            return;

        var entity = new VpnAccessCard
        {
            CardNumber = newCardNumber,
            AssignedAdUser = newCardAssignedUser,
            Pin = newCardPin,
            Notes = newCardNotes,
            IssuedAt = string.IsNullOrWhiteSpace(newCardAssignedUser) ? null : DateTime.Now
        };

        await RunInventoryActionAsync(async () =>
        {
            await VpnInventoryService.AddCardAsync(entity);
            newCardNumber = string.Empty;
            newCardAssignedUser = string.Empty;
            newCardPin = string.Empty;
            newCardNotes = string.Empty;
        }, "Karte angelegt.");
    }

    private async Task SaveCardAsync(VpnAccessCard row)
    {
        row.IssuedAt = string.IsNullOrWhiteSpace(row.AssignedAdUser) ? null : row.IssuedAt ?? DateTime.Now;
        await RunInventoryActionAsync(async () => await VpnInventoryService.UpdateCardAsync(row), "Karte gespeichert.");
    }

    private async Task DeleteCardAsync(int id)
    {
        await RunInventoryActionAsync(() => VpnInventoryService.DeleteCardAsync(id), "Karte gelöscht.");
    }

    private async Task RunInventoryActionAsync(Func<Task> action, string successMessage)
    {
        inventoryBusy = true;
        inventoryMessage = string.Empty;

        try
        {
            await action();
            await LoadInventoryAsync();
            inventoryMessage = successMessage;
        }
        catch (DbUpdateException)
        {
            inventoryMessage = "Speichern fehlgeschlagen. Serien- oder Kartennummer existiert bereits.";
        }
        finally
        {
            inventoryBusy = false;
        }
    }

    private async Task LoadAllUsersAsync()
    {
        isLoading = true;
        encodedResults.Clear();
        StateHasChanged();

        var allUsers = await AdService.GetAllUsersAsync();
        results = allUsers
            .Where(u => OuAccessService.CanAccessUser(u.DistinguishedName, isAdmin))
            .OrderBy(u => u.DisplayName)
            .ToList();

        resultTitle = "Benutzerliste (Alle)";
        selectedUsers.Clear();
        isLoading = false;
    }

    private async Task OnSearchChangedAsync(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;

        if (searchTerm.Length < 2)
        {
            results = null;
            selectedUsers.Clear();
            return;
        }

        isLoading = true;
        StateHasChanged();

        var searchedUsers = await AdService.SearchUsersAsync(searchTerm);
        results = searchedUsers
            .Where(u => OuAccessService.CanAccessUser(u.DistinguishedName, isAdmin))
            .OrderBy(u => u.DisplayName)
            .ToList();

        resultTitle = $"Suchergebnisse für \"{searchTerm}\"";
        selectedUsers.Clear();
        isLoading = false;
    }

    private void ClearSearch()
    {
        searchTerm = string.Empty;
        results = null;
        selectedUsers.Clear();
    }

    private void ToggleSelection(string sam, bool isSelected)
    {
        if (isSelected)
            selectedUsers.Add(sam);
        else
            selectedUsers.Remove(sam);
    }

    private void ToggleAllSelections()
    {
        if (!CanSelectAll || results is null)
            return;

        if (AllSelected)
        {
            selectedUsers.Clear();
            return;
        }

        selectedUsers.Clear();
        foreach (var user in results)
            selectedUsers.Add(user.SamAccountName);
    }

    private void GenerateHex64Strings()
    {
        if (!CanSelectAll || results is null)
            return;

        encodedResults.Clear();

        var selectedEntries = results
            .Where(u => selectedUsers.Contains(u.SamAccountName))
            .Select(u => new
            {
                u.DisplayName,
                Upn = GetUpn(u),
                Status = u.IsEnabled ? "Enable" : "Disable"
            })
            .Where(x => !string.IsNullOrWhiteSpace(x.Upn))
            .OrderBy(x => x.Upn)
            .ToList();

        foreach (var entry in selectedEntries)
        {
            encodedResults.Add(new EncodedVpnUser(
                entry.DisplayName,
                entry.Upn,
                entry.Status,
                EncodeHex64(entry.Upn)));
        }
    }

    private async Task ExportCsvAsync()
    {
        if (encodedResults.Count == 0)
            return;

        var builder = new StringBuilder();
        builder.AppendLine("DisplayName,UPN,Status,HEX64");

        foreach (var item in encodedResults)
            builder.AppendLine($"{Csv(item.DisplayName)},{Csv(item.Upn)},{Csv(item.Status)},{Csv(item.Encoded)}");

        var bytes = Encoding.UTF8.GetBytes(builder.ToString());
        var base64 = Convert.ToBase64String(bytes);
        var filename = $"vpn-hex64-{DateTime.Now:yyyyMMdd-HHmmss}.csv";

        await JS.InvokeVoidAsync("downloadBase64File", filename, "text/csv;charset=utf-8", base64);
    }

    private static bool ParseCheckboxValue(object? value)
    {
        if (value is bool boolValue)
            return boolValue;

        return string.Equals(value?.ToString(), "true", StringComparison.OrdinalIgnoreCase);
    }

    private static string Csv(string value)
    {
        var safe = (value ?? string.Empty).Replace("\"", "\"\"");
        return $"\"{safe}\"";
    }

    private static string GetUpn(AdUserResult user) =>
        string.IsNullOrWhiteSpace(user.UserPrincipalName) ? user.Email : user.UserPrincipalName;

    private static string FormatDate(DateTime? value) => value?.ToString("dd.MM.yyyy HH:mm") ?? "-";

    private static string EncodeHex64(string value)
    {
        var bytes = Encoding.UTF8.GetBytes(value);
        var hex = Convert.ToHexString(bytes);
        return Convert.ToBase64String(Encoding.UTF8.GetBytes(hex));
    }

    private sealed class EncodedVpnUser(string displayName, string upn, string status, string encoded)
    {
        public string DisplayName { get; } = displayName;
        public string Upn { get; } = upn;
        public string Status { get; } = status;
        public string Encoded { get; } = encoded;
    }
}
